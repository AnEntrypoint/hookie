  {
    "id": "fix-pagecard-ux",
    "subject": "Replace PageCard flip-to-confirm UX with inline action buttons using Tailwind/Ripple classes",
    "status": "pending",
    "description": "PageCard uses a 'flip' pattern (transforms the whole card) for delete confirmation and duplicate name input. This is disorienting and breaks grid layout consistency. Replace with: delete uses a simple window.confirm(), duplicate opens a small input that appends below the card actions row. Also migrate PageCard from inline style objects to Tailwind/Ripple UI classes to match the rest of the admin.",
    "blocking": [],
    "blockedBy": [],
    "effort": "small",
    "category": "feature",
    "acceptance": [
      "PageCard uses Tailwind/Ripple classes instead of style objects from pageCardStyles",
      "Delete button uses window.confirm() for confirmation instead of flipping the card",
      "Duplicate shows a small inline input row below the action buttons (no card flip)",
      "Card dimensions remain stable regardless of confirmation state",
      "pageCardStyles.js is no longer imported"
    ],
    "edge_cases": [
      "If duplicateName input is shown, pressing Enter submits, Escape cancels",
      "window.confirm is synchronous so no async state needed for delete confirm"
    ]
  }
