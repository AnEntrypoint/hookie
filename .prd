  {
    "id": "fix-github-btoa-utf8",
    "subject": "Fix github.js btoa encoding for non-ASCII content",
    "status": "pending",
    "description": "writeFile uses btoa(content) which fails for Unicode/non-ASCII characters. Must use TextEncoder or encodeURIComponent pattern. Silently breaks page saves with smart quotes, em-dashes, or non-Latin text.",
    "blocking": [
      "final-polish-and-docs"
    ],
    "blockedBy": [],
    "effort": "small",
    "category": "bug",
    "acceptance": [
      "Pages with emoji content save successfully",
      "UTF-8 characters survive round-trip",
      "btoa never throws InvalidCharacterError"
    ],
    "edge_cases": [
      "Very large pages",
      "JSON with escaped unicode sequences"
    ]
  },
  {
    "id": "fix-componentregistry-richschemas",
    "subject": "Fix component registry schemas to match actual component implementations",
    "status": "pending",
    "description": "Registry schemas are mismatched with implementations. Button schema has text+onClick but component accepts label/variant/size/disabled/fullWidth. All 12 schemas need to match their actual implementations. PropsEditor renders wrong controls because of this mismatch.",
    "blocking": [
      "add-hero-component",
      "add-testimonial-component",
      "add-navbar-component",
      "add-footer-component",
      "add-pricing-component",
      "add-form-component",
      "improve-component-schemas"
    ],
    "blockedBy": [],
    "effort": "medium",
    "category": "bug",
    "acceptance": [
      "Button schema has label, variant (enum), size (enum), disabled, fullWidth",
      "Text schema has content, size, color, weight, align",
      "Heading schema has text, level, color, align",
      "Section schema has title, subtitle, padding (enum), background (enum), fullWidth",
      "Grid schema has columns, gap",
      "Container schema has maxWidth, padding",
      "Image schema has src, alt, objectFit",
      "Link schema has href, text, target",
      "All schemas have correct defaults matching component defaults"
    ],
    "edge_cases": [
      "Enum values must exactly match component prop values",
      "Default values must produce valid rendered output"
    ]
  },
  {
    "id": "fix-builder-selection-sidebar",
    "subject": "Fix builder - PropsEditor never shows because selection state is not shared",
    "status": "pending",
    "description": "In AdminApp.renderView(), the sidebar PropsEditor depends on selectedComponentId from AdminApp state. But selection happens inside Builder.js with its own local state. The two are never synced. The outer sidebar PropsEditor is dead code. Fix by adding onSelectComponent callback from Builder to AdminApp, or move PropsEditor entirely into Builder.",
    "blocking": [
      "improve-adminapp-layout",
      "fix-renderer-edit-mode"
    ],
    "blockedBy": [],
    "effort": "medium",
    "category": "bug",
    "acceptance": [
      "Clicking component in canvas shows PropsEditor with correct props",
      "Changing props in editor updates canvas in real-time",
      "Deselecting clears the editor",
      "Switching pages resets selection"
    ],
    "edge_cases": [
      "Deleting selected component clears sidebar",
      "Component with no props shows empty state"
    ]
  },
