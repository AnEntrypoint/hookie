            "content": "// AnEntrypoint",
            "size": "sm",
            "color": "#00ff88",
            "weight": "bold",
            "align": "left"
          },
          "style": {
            "fontFamily": "monospace",
            "letterSpacing": "0.1em",
            "marginBottom": "1rem"
          },
          "children": []
